# Restaurant Outreach Machine — Environment Variables
# Copy to .env.local (web app) and mcp-server/.env (MCP server)
# NEVER commit either file to version control

# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Google OAuth (for Gmail) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── NextAuth ───────────────────────────────────────────────
NEXTAUTH_SECRET=         # generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# ── Firecrawl (web scraping — optional, Cheerio fallback if missing) ──
FIRECRAWL_API_KEY=

# ── MCP Server ────────────────────────────────────────────
MCP_SERVER_PORT=3001
MCP_SERVER_SECRET=       # shared secret between Next.js and MCP server
MCP_SERVER_URL=http://localhost:3001

# ── Gmail Sender ──────────────────────────────────────────
GMAIL_SENDER_EMAIL=uddaloc24@gmail.com

# ── Stripe (legacy — kept for existing one-time purchases) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Dodo Payments (D2C subscription billing) ──────────
DODO_API_KEY=                 # production key from app.dodopayments.com
DODO_API_KEY_TEST=            # test/sandbox key
DODO_WEBHOOK_SECRET=          # webhook signature verification
DODO_TEST_MODE=true           # set to "false" for production

# Dodo product IDs — create 3 products × 4 regions in Dodo dashboard
DODO_PRODUCT_US_STARTER=
DODO_PRODUCT_US_PRO=
DODO_PRODUCT_US_ELITE=
DODO_PRODUCT_EU_STARTER=
DODO_PRODUCT_EU_PRO=
DODO_PRODUCT_EU_ELITE=
DODO_PRODUCT_IN_STARTER=
DODO_PRODUCT_IN_PRO=
DODO_PRODUCT_IN_ELITE=
DODO_PRODUCT_ROW_STARTER=
DODO_PRODUCT_ROW_PRO=
DODO_PRODUCT_ROW_ELITE=
